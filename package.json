{
  "name": "consulto-survey",
  "description": "Plugin WordPress per la gestione di sondaggi con supporto a **voto preferenziale (ranking / partial ranking)**, progettato per contesti della pubblica amministrazione.",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "scripts": {
    "test": "jest",
    "build": "webpack",
    "watch": "webpack --watch"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
        "@testing-library/jest-dom",
        "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "\\.(css|less)$": "<rootDir>/__mocks__/fileMock.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comuneditrapani/consulto-survey.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/comuneditrapani/consulto-survey/issues"
  },
  "homepage": "https://github.com/comuneditrapani/consulto-survey#readme"
}
